# apps/suize/.env.production: PUBLIC Vite build config, safe to commit.
# Bakes mainnet into a plain `bun run build`. config.ts defaults to testnet
# unless VITE_SUI_NETWORK==='mainnet', so without this file a prod build would
# silently regress to testnet. This is a public network selector only, never a
# secret (whitelisted in the root .gitignore alongside the other apps' prod env).
VITE_SUI_NETWORK=mainnet
