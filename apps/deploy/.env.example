# ============================================================================
# Suize Deploy — dashboard environment (Vite). Copy to `.env` and fill in.
#   cp .env.example .env
# ----------------------------------------------------------------------------
# WITHOUT any keys the dashboard STILL builds and runs: it talks to the local
# backend at http://localhost:8080 and shows empty/loading states until the
# backend's `deploy` module is reachable + configured (DEPLOY_WALLET_PRIVATE_KEY).
# ============================================================================

# Deploy backend base URL — the unified Suize backend's `deploy` module
#   (POST /deploy, GET /sites, GET /sites/:id, POST /domains, DELETE /domains/:domain).
#   The route is OPEN (no auth in the MVP). Leave UNSET to default to the local
#   backend at http://localhost:8080. In prod this is the unified backend host
#   (one host for sponsor + api + deploy), e.g. https://api.suize.io
VITE_DEPLOY_API_URL=

# ----------------------------------------------------------------------------
# OPTIONAL — Suize-wallet (Google / zkLogin) login. Used ONLY to scope "your
# sites" by owner address (the deploy route stays OPEN; login is just a filter
# and the seam future payments hang off — see docs/deploy/SPEC.md §8, §12).
# WITHOUT these the dashboard shows all sites and a plain "Connect wallet" button.
# ----------------------------------------------------------------------------

# Enoki API key (the PUBLIC, browser-safe key for this app).
#   https://portal.enoki.mystenlabs.com — create a TESTNET app, copy the public key.
#   No sponsorship allowlist is needed here: deploys are paid by the backend's own
#   service wallet, not Enoki — login is read-only attribution.
VITE_ENOKI_API_KEY=

# Google OAuth Web client ID.
#   https://console.cloud.google.com/apis/credentials — OAuth 2.0 "Web application".
#   Add this app origin (e.g. http://localhost:5183) to Authorized JavaScript
#   origins AND the `${origin}/enoki` redirect to Authorized redirect URIs, then
#   register the client ID in your Enoki app's Google provider.
VITE_GOOGLE_CLIENT_ID=
