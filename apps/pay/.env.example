# @suize/pay-app — env template. Copy to .env (gitignored) and fill the values.
# All values here are PUBLIC publishable ids (build-time Vite-inlined) — never a
# secret. The Enoki PRIVATE key lives only in services/backend/.env.

# Network — only the exact string 'mainnet' opts in; anything else = testnet.
VITE_SUI_NETWORK=testnet

# Enoki seedless Google zkLogin — the wallet's EXACT config (same publishable
# Enoki key + the load-bearing Google OAuth client id; the client id is pinned
# forever — it is the zkLogin `aud`, never rotate it). When BOTH are set the
# Enoki Google wallet auto-registers into dapp-kit. The OAuth redirect REUSES
# the suite's one registered URI `${origin}/enoki` (NO /pay-prefixed variant
# exists): prod = https://wallet.suize.io/enoki (ALREADY registered — served by
# the wallet app; the OAuth popups only park there while the pay/connect opener
# reads the fragment); dev = http://localhost:5173/enoki (served by this app's
# vite middleware — ALREADY registered on the owner's OAuth client). Google
# OAuth client requirements: Authorized redirect URIs must contain
# http://localhost:5173/enoki (dev) — prod needs NOTHING new; and Authorized
# JavaScript origins must contain http://localhost:5173 (dev) /
# https://wallet.suize.io (prod, already there) + the Enoki Portal config.
VITE_ENOKI_API_KEY=
VITE_GOOGLE_CLIENT_ID=

# Sui fullnode RPC override (optional — defaults to the public fullnode).
#VITE_SUI_RPC_URL=

# The unified backend (x402 facilitator: /terms, /build, /verify, /settle).
# Unset: dev defaults to http://localhost:8099 (services/backend .env PORT),
# prod builds default to https://api.suize.io.
#VITE_SUIZE_API=
