# Copy to .env.local and fill in values. Anything prefixed with VITE_ is
# exposed to the client at build time — never put real secrets here.

# Override the outbound product links for local dev (e.g. point the CTAs at a
# locally-running app). Defaults live in src/links.js.
# VITE_WALLET_URL=http://localhost:5173
# VITE_CRASH_URL=http://localhost:5174
