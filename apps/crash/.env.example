# ============================================================================
# Crash Sui — environment (Vite). Copy to `.env` and fill in.
#   cp .env.example .env
# ----------------------------------------------------------------------------
# WITHOUT these keys the app STILL builds and runs: it falls back to a normal
# wallet connect button (any Sui testnet wallet extension). The keys are only
# needed for the full-invisible flow: "Sign in with Google" (zkLogin) + gasless
# sponsored transactions, so a user needs neither a seed phrase nor SUI for gas.
# ============================================================================

# Enoki API key (the PUBLIC, browser-safe key for this app).
#   Get it at: https://portal.enoki.mystenlabs.com
#   Create an app -> copy the "Public API key". Set the network to TESTNET.
#   In the SAME portal app, enable "Sponsored Transactions" and ALLOWLIST EXACTLY
#   the seven move-call targets — and ONLY these. Every user action flows through
#   our router, so nothing else needs sponsorship. The exact list is the single
#   source of truth `ALLOWED_MOVE_TARGETS` in src/config.ts; mirror it verbatim:
#     <router_pkg>::router::create_manager
#     <router_pkg>::router::bet
#     <router_pkg>::router::cash_out
#     <router_pkg>::router::claim
#     <router_pkg>::router::withdraw
#     <router_pkg>::router::supply
#     <router_pkg>::router::redeem_lp
#   where <router_pkg> = 0x885bc905f8c39a8a179a6013a4a688c19d94f49ae3a98653452f97dcaff9d2c3
#   Native PTB commands (SplitCoins/MergeCoins/TransferObjects) are NOT
#   allowlisted by Enoki — only moveCall targets are — so a PTB doing
#   SplitCoins + router::bet is sponsorable with just the seven targets above.
#   NOTE: this Portal allowlist is the ENFORCED backstop — per-request
#   `allowedMoveCallTargets` is not reachable from a browser/public key in
#   @mysten/enoki 1.0.8 (see the ALLOWED_MOVE_TARGETS comment in src/config.ts).
VITE_ENOKI_API_KEY=

# Google OAuth Web client ID.
#   Get it at: https://console.cloud.google.com/apis/credentials
#   Create OAuth 2.0 Client ID -> type "Web application".
#   Add your app origin to "Authorized JavaScript origins" (e.g.
#   http://localhost:5173) and the same origin to "Authorized redirect URIs"
#   (Enoki uses the page origin as the redirect by default). Then register this
#   client ID in your Enoki portal app's Google auth provider.
VITE_GOOGLE_CLIENT_ID=

# Gas sponsor backend base URL (the unified Suize backend's /sponsor + /execute).
#   zkLogin (Google) users hold a fresh address with NO SUI for gas, so their
#   writes are routed through this backend, which holds the Enoki PRIVATE key and
#   sponsors gas for the seven allowlisted router::* targets (the allowlist is
#   enforced SERVER-SIDE there — see services/backend/src/sponsor). Normal wallet
#   users (e.g. Slush) pay their own gas and never hit this endpoint.
#   Leave UNSET for local dev to default to the backend's local port
#   (services/backend/.env -> PORT, currently 8099): http://localhost:8099
#   In prod the unified backend is ONE host (no separate sponsor host): the
#   /sponsor + /execute routes live on the api host, e.g. https://api.suize.io
VITE_SPONSOR_URL=

# NOTE: there is intentionally NO treasury env var. The 3% platform fee is
# enforced ON-CHAIN by a Move router (crash_sui::router::bet), which stores the
# treasury address inside its shared config object. A client-side fee is
# bypassable and a treasury address must never live in client code, so the
# router + treasury are owned on-chain. See ROUTER_* in src/config.ts.
