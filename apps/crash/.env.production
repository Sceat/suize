# Production build env for the crash game (apps/crash). Vite loads this in `build`
# mode on top of .env, overriding the dev localhost WS with the live backend.
# All PUBLIC, build-time-inlined frontend values (they ship in the bundle) — safe
# to commit. The deploy is PREBUILT (built locally), so THIS file is the source of
# truth for prod config, not the Vercel dashboard env.

# Publishable Enoki key (zkLogin) — public. Same Enoki app as the wallet.
VITE_ENOKI_API_KEY=enoki_public_ff89078fe8efa82d3f14732264813b91

# Google OAuth client id (zkLogin via Enoki) — public. Authorize crash.suize.io
# as an allowed origin/redirect in Google Cloud + Enoki Portal for sign-in.
VITE_GOOGLE_CLIENT_ID=313146835988-grmmshtte3s80efmm8sm6kviu0v8no8r.apps.googleusercontent.com

# Live backend WS — the gasless sponsor transport (sponsor + execute ride this one
# Enoki-verified WebSocket now, NOT HTTP). Prod = wss://api.suize.io/ws. Trailing
# slash stripped by ws.ts; it appends the ?address= query param at connect time.
VITE_WS_URL=wss://api.suize.io/ws
