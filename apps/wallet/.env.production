# Production build env for the wallet (apps/wallet). Vite loads this in `build`
# mode (vite build / vercel build --prod) ON TOP of .env, so it overrides the dev
# VITE_WS_URL with the live backend. These are all PUBLIC, build-time-inlined
# frontend values (they ship in the JS bundle) — safe to commit. Secrets never
# live here; the wallet only ever holds publishable ids + public addresses.
#
# The deploy is PREBUILT (built locally, shipped to Vercel), so THIS file is the
# source of truth for prod config — not the Vercel dashboard env (whose CLI
# `env add` silently drops piped values in v54; set them in the UI only if you
# ever switch to Vercel cloud builds).

# Publishable Enoki key (zkLogin) — public.
VITE_ENOKI_API_KEY=enoki_public_ff89078fe8efa82d3f14732264813b91

# Google OAuth client id (zkLogin via Enoki) — public. Authorize wallet.suize.io
# as an allowed origin/redirect in Google Cloud + Enoki Portal for sign-in to work.
VITE_GOOGLE_CLIENT_ID=313146835988-grmmshtte3s80efmm8sm6kviu0v8no8r.apps.googleusercontent.com
VITE_GOOGLE_AGENT_CLIENT_ID=313146835988-2hn363kbg8ap9jt3cgvr5fdlruaja3jn.apps.googleusercontent.com

# Live backend WS — the wallet's only transport. Prod = wss://api.suize.io/ws.
VITE_WS_URL=wss://api.suize.io/ws

# The scoped AI agent's PUBLIC Sui address (off-chain helm keypair). Needed for
# account creation (mandate::issue_agent_cap); sign-in + onboarding work without it.
VITE_AGENT_ADDRESS=0xcc58bc000f36b139efe4c951d0d2f3fdf47da9ea6d6d0c2e099bd4f726d9496e
