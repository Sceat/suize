# Suize frontend env. Network is testnet (locked) — real DeepBook spot liquidity on
# testnet, matches the Move deploy target and the backend sponsor.

VITE_SUI_NETWORK=testnet

# Sui fullnode RPC override. Unset = the public fullnode for VITE_SUI_NETWORK.
VITE_SUI_RPC_URL=

# Enoki (seedless Google zkLogin + sponsored txs). Auth is REAL zkLogin only — there
# is NO fallback session. When BOTH are set, the Enoki Google wallet registers into
# dapp-kit and sign-in runs real Google OAuth. Leave empty and sign-in THROWS, so
# App.tsx redirects to suize.io (we never fabricate a fake address/session).
VITE_ENOKI_API_KEY=
VITE_GOOGLE_CLIENT_ID=

# A SECOND Google OAuth client id — the /agent-connect door. The external agent (MCP)
# signs in under a DISTINCT zkLogin identity (a different `aud`) so its address is its
# OWN (the human wallet can never sweep it). Empty => /agent-connect shows the
# not-configured state (it cannot mint an agent session). PUBLISHABLE (an OAuth client
# id, not a secret).
VITE_GOOGLE_AGENT_CLIENT_ID=

# Backend HTTP base (the x402 V2 facilitator: /verify · /settle · /build · /terms) —
# used ONLY by the /confirm SSO popup (the wallet's money verbs ride the WS). Unset =>
# dev falls back to http://localhost:8099, prod to https://api.suize.io.
VITE_SUIZE_API=

# Single Enoki-verified WebSocket — the wallet's ONE data transport (handle + sponsor +
# execute + balance pushes all ride this one socket). Replaces the old HTTP sponsor base.
# Dev: ws://localhost:8080/ws (the backend's default PORT) · prod: wss://api.suize.io/ws.
# Default if unset: localhost:8080/ws.
VITE_WS_URL=ws://localhost:8080/ws

# The scoped AI agent's Sui ADDRESS (0x…) — the destination the owner-minted AgentCap
# is transferred to at account creation (mandate::issue_agent_cap). The agent PRIVATE
# key lives ONLY in the off-chain helm, never here. Empty => account creation throws
# "agent not configured" (an owner action). Set to the helm keypair's testnet address.
VITE_AGENT_ADDRESS=
