# @suize/agents-app — env template. Copy to .env (gitignored) and fill the values.
# All values here are PUBLIC publishable ids (build-time Vite-inlined) — never a
# secret. The Enoki PRIVATE key lives only in services/backend/.env.

# Network — only the exact string 'mainnet' opts in; anything else = testnet.
VITE_SUI_NETWORK=testnet

# Enoki seedless Google zkLogin — the suite's EXACT config (same publishable
# Enoki key + the load-bearing Google OAuth client id; the client id is pinned
# forever — it is the zkLogin `aud`, never rotate it). When BOTH are set the
# Enoki Google wallet auto-registers into dapp-kit, so a visitor can sign in and
# place an ad-slot bid without leaving the page. The OAuth redirect reuses the
# suite's one registered URI `${origin}/enoki`: dev = http://localhost:5174/enoki
# (add it to the OAuth client's Authorized redirect URIs + JavaScript origins);
# prod = https://agents.suize.io/enoki (register it once).
VITE_ENOKI_API_KEY=
VITE_GOOGLE_CLIENT_ID=

# Sui fullnode RPC override (optional — defaults to the public fullnode).
#VITE_SUI_RPC_URL=

# The unified backend (the directory's read endpoints: /feed, /rankings, /stats,
# /ads/slots). Unset: dev defaults to http://localhost:8099 (services/backend .env
# PORT), prod builds default to https://api.suize.io.
#VITE_SUIZE_API=
