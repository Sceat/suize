{
  "name": "@suize/backend",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "deploy-as-agent": "bun run scripts/deploy-as-agent.ts",
    "subs:sync-config": "bun run scripts/sync-subs-config.ts",
    "auction:sync-config": "bun run scripts/sync-auction-config.ts",
    "check:arity": "bun run scripts/check-ptb-arity.ts",
    "push": "bash scripts/push.sh",
    "push:patch": "bash scripts/push.sh patch",
    "push:minor": "bash scripts/push.sh minor",
    "push:major": "bash scripts/push.sh major"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@mysten-incubation/memwal": "^0.0.7",
    "@mysten/enoki": "^1.0.8",
    "@mysten/seal": "^1.1.3",
    "@mysten/sui": "^2.17.0",
    "@mysten/suins": "^1.1.4",
    "@suize/pay": "workspace:*",
    "@suize/shared": "workspace:*",
    "@suize/x402": "workspace:*",
    "nanotar": "^0.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
