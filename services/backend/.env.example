# @suize/backend — env var NAMES only. NEVER commit real values.
# Copy to `.env` (gitignored) and fill in locally; in k8s these come from the
# SOPS-encrypted secret.

# Shared
PORT=8080
# Comma-separated CORS allow-list. Defaults (if unset) cover both apps:
#   https://crash.suize.io,http://localhost:5173,https://suize.io,http://localhost:5180
ALLOWED_ORIGINS=

# Sui network — ENV-ONLY selection ('mainnet' opts in; anything else/unset = testnet).
SUI_NETWORK=testnet
# Sui RPC endpoints — comma-separated, FIRST entry is the primary. Precedence:
# SUI_RPC_URLS > SUI_RPC_URL (legacy single) > the public fullnode for SUI_NETWORK.
SUI_RPC_URLS=
SUI_RPC_URL=
# Enoki PRIVATE key from the Enoki Portal (NOT the public key). SECRET.
ENOKI_PRIVATE_API_KEY=

# Gas-drain ceilings (optional — defaults are demo-generous). Process-global daily
# caps (in-memory, reset every 24h) that bound how much of the Enoki sponsor pool /
# deploy wallet this replica will spend before returning 429. Per-replica, not
# cross-replica; Enoki's own pool budget is the ultimate hard cap.
# SPONSOR_DAILY_MAX=20000              # sponsored txs / day / replica
# SPONSOR_DAILY_PER_ADDRESS_MAX=500    # sponsored txs / day / address
# DEPLOY_DAILY_MAX=200                 # deploys / day / replica (each pays real SUI gas)

# Handle (self-custody SuiNS) module — Path B, FULLY ON-CHAIN (no Redis).
# The handle module is ENABLED only when SUINS_PARENT_NFT_ID + HANDLE_ISSUER_PRIVATE_KEY
# are set; until then handle ops return 503 "handle issuance not configured"
# (the rest of the backend runs fine). Availability/idempotency/reverse are all
# read from chain via the Sui SDK; ENOKI_PRIVATE_API_KEY sponsors the leaf-subname
# mint gas AND the user's setDefault (set_reverse_lookup) tx.
# Object id of the parent `suize.sui` SuinsRegistration NFT, custodied by the issuer address.
SUINS_PARENT_NFT_ID=
# Bech32 `suiprivkey...` of the issuer keypair that holds the parent NFT and signs leaf mints. SECRET.
# SEPARATE from ENOKI_PRIVATE_API_KEY and the future AGENT_PRIVATE_KEY — never reuse keys.
HANDLE_ISSUER_PRIVATE_KEY=
# Parent SuiNS domain (defaults to suize.sui if unset). Handles are <name>@suize = <name>.suize.sui.
SUINS_PARENT_DOMAIN=suize.sui

# Deploy module — "Suize Deploy" (Vercel for Sui). FULLY ON-CHAIN site registry.
# The module is ENABLED only when DEPLOY_WALLET_PRIVATE_KEY is set; until then
# every /deploy, /sites, /domains op returns 503 "deploy not configured" (the rest
# of the backend runs fine). Storage goes through the Walrus HTTP PUBLISHER (no CLI);
# there is NO Enoki sponsor here (the agent signs nothing).
#
# Bech32 `suiprivkey...` of the deploy SERVICE WALLET that signs Site PTBs. SECRET.
# SEPARATE from ENOKI_PRIVATE_API_KEY / HANDLE_ISSUER_PRIVATE_KEY — never reuse keys.
# On the PUBLIC TESTNET publisher the OPERATOR pays the WAL, so this wallet needs only
# a LITTLE SUI for the on-chain create_site gas — no WAL needed for testnet.
DEPLOY_WALLET_PRIVATE_KEY=
# Walrus storage duration in epochs (default 30 ≈ ~2 months; testnet epoch ≈ 2 days, max 183).
DEPLOY_EPOCHS=30
# Base zone for free subdomains: https://<base36(siteId)>.<DEPLOY_BASE_DOMAIN>. Default deploy.suize.io.
DEPLOY_BASE_DOMAIN=deploy.suize.io
# Walrus AGGREGATOR base (used to READ back uploaded blobs; the worker uses the same).
# Unset = the public aggregator for SUI_NETWORK (shared WALRUS_DEFAULTS table).
WALRUS_AGGREGATOR=
# Walrus HTTP PUBLISHER base — the deploy module PUTs quilts/blobs here (no CLI, no keystore).
# Unset = the public publisher for SUI_NETWORK (on testnet the operator pays the WAL).
# The SAME code serves a self-hosted MAINNET publisher — just point this at it.
WALRUS_PUBLISHER_URL=

# Optional Cloudflare-for-SaaS (Custom Hostnames) adapter — custom-domain auto-SSL.
# When BOTH are set the deploy module provisions the custom hostname on link;
# otherwise it returns manual-CNAME instructions (never a build blocker).
# Cloudflare API token with the "Custom Hostnames Edit" scope. SECRET.
CF_API_TOKEN=
# Cloudflare zone id that hosts DEPLOY_BASE_DOMAIN.
CF_ZONE_ID=

# Renewal relayer — the deterministic subscription↔storage cron. Enabled only when
# DEPLOY_WALLET_PRIVATE_KEY is set AND the rail charge gate is live (account package
# published + RailConfig + Deploy merchant pinned in @suize/shared). Each tick it
# walks the on-chain RenewalRegistry; a DUE subscription gets ONE service-wallet PTB
# (charge_subscription + extend_blob × 2 — the user is charged IFF storage extends).
# NOTE: extends pay WAL — the deploy service wallet must hold a Coin<WAL>.
# Loop interval in ms (default 60000 = 1 min).
# RENEWAL_TICK_MS=60000
# Walrus epochs added per extend (default 35; clamped so a blob never ends more
# than ~50 epochs past the current epoch — the Walrus max is ~53).
# RENEWAL_EPOCHS=35
# Extend-only cushion (default 5): a blob ending within this many epochs of NOW,
# inside an already-paid period, is re-extended WITHOUT charging (repairs the
# griefed-permissionless-charge case).
# RENEWAL_SAFETY_EPOCHS=5
# Deploy subscription period in ms. Default = the shared 30-day constant; override
# ONLY for demos (e.g. 120000 = 2-minute periods, paired with a short tick).
# DEPLOY_SUB_PERIOD_MS=
# WAL coin type the extend payment is drawn from (default = testnet WAL; set for mainnet).
# WAL_COIN_TYPE=
# Walrus shared System object id (default = testnet; set for mainnet). The Walrus
# PACKAGE is resolved at runtime from this object's package_id field — never pinned.
# WALRUS_SYSTEM_OBJECT=
