# @suize/backend — env var NAMES only. NEVER commit real values.
# Copy to `.env` (gitignored) and fill in locally; in k8s these come from the
# SOPS-encrypted secret.

# Shared
PORT=8080
# Comma-separated CORS allow-list. Defaults (if unset) cover both apps:
#   https://crash.suize.io,http://localhost:5173,https://suize.io,http://localhost:5180
ALLOWED_ORIGINS=

# Sponsor module
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# Enoki PRIVATE key from the Enoki Portal (NOT the public key). SECRET.
ENOKI_PRIVATE_API_KEY=

# API / waitlist module
REDIS_URL=redis://localhost:6379
# Cloudflare Turnstile secret. SECRET.
TURNSTILE_SECRET=

# Handle (self-custody SuiNS) module — Path B.
# The handle module is ENABLED only when SUINS_PARENT_NFT_ID + HANDLE_ISSUER_PRIVATE_KEY
# are set; until then GET/POST /handle/* return 503 "handle issuance not configured"
# (the rest of the backend runs fine). Reuses REDIS_URL (source of truth) +
# ENOKI_PRIVATE_API_KEY (sponsors the leaf-subname mint gas).
# Object id of the parent `suize.sui` SuinsRegistration NFT, custodied by the issuer address.
SUINS_PARENT_NFT_ID=
# Bech32 `suiprivkey...` of the issuer keypair that holds the parent NFT and signs leaf mints. SECRET.
# SEPARATE from ENOKI_PRIVATE_API_KEY and the future AGENT_PRIVATE_KEY — never reuse keys.
HANDLE_ISSUER_PRIVATE_KEY=
# Parent SuiNS domain (defaults to suize.sui if unset). Handles are <name>@suize = <name>.suize.sui.
SUINS_PARENT_DOMAIN=suize.sui
