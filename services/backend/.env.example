# @suize/backend — env var NAMES only. NEVER commit real values.
# Copy to `.env` (gitignored) and fill in locally; in k8s these come from the
# SOPS-encrypted secret.

# Shared
PORT=8080
# Comma-separated CORS allow-list. Defaults (if unset) cover both apps:
#   https://crash.suize.io,http://localhost:5173,https://suize.io,http://localhost:5180
ALLOWED_ORIGINS=

# Sui network — ENV-ONLY selection ('mainnet' opts in; anything else/unset = testnet).
SUI_NETWORK=testnet
# Sui RPC endpoints — comma-separated, FIRST entry is the primary. Precedence:
# SUI_RPC_URLS > SUI_RPC_URL (legacy single) > the public fullnode for SUI_NETWORK.
SUI_RPC_URLS=
SUI_RPC_URL=
# Enoki PRIVATE key from the Enoki Portal (NOT the public key). SECRET.
ENOKI_PRIVATE_API_KEY=

# Gas-drain ceilings (optional — defaults are demo-generous). Process-global daily
# caps (in-memory, reset every 24h) that bound how much of the Enoki sponsor pool /
# deploy wallet this replica will spend before returning 429. Per-replica, not
# cross-replica; Enoki's own pool budget is the ultimate hard cap.
# SPONSOR_DAILY_MAX=20000              # sponsored txs / day / replica
# SPONSOR_DAILY_PER_ADDRESS_MAX=500    # sponsored txs / day / address
# DEPLOY_DAILY_MAX=200                 # deploys / day / replica (each pays real SUI gas)

# Hosted pay page base URL — POST /checkout assembles pay-links against this
# (pure string formatting, no store — SPEC §7.3). The page serves under the /pay
# BASE PATH on the wallet's origin (own pay domain DROPPED), so the value ENDS
# IN /pay and a link is <base>?payTo=…. Default https://wallet.suize.io/pay;
# override for dev (e.g. http://localhost:5173). Trailing slashes are
# stripped (the /pay path itself is kept).
# PAY_PAGE_URL=https://pay.suize.io

# Facilitator fee-tier merchant registry (x402 V2). JSON map of the ONLY addresses
# that get a 2% (+ $0.01 floor) rake declared in their 402 outputs:
#   {"0x<addr>":{"feeBps":200}}
# Any payTo NOT in this map is FREE tier (single full-amount output, no rake).
# Unset/empty = every merchant is free tier. The rake lands at the treasury
# resolved from the SuiNS name `treasury@suize` (TREASURY_ADDRESSES fallback on
# testnet; FAIL-CLOSED on mainnet until pinned).
# SUIZE_MERCHANTS={"0x...":{"feeBps":200}}

# Handle (self-custody SuiNS) module — Path B, FULLY ON-CHAIN (no Redis).
# The handle module is ENABLED only when SUINS_PARENT_NFT_ID + HANDLE_ISSUER_PRIVATE_KEY
# are set; until then handle ops return 503 "handle issuance not configured"
# (the rest of the backend runs fine). Availability/idempotency/reverse are all
# read from chain via the Sui SDK; ENOKI_PRIVATE_API_KEY sponsors the leaf-subname
# mint gas AND the user's setDefault (set_reverse_lookup) tx.
# Object id of the parent `suize.sui` SuinsRegistration NFT, custodied by the issuer address.
SUINS_PARENT_NFT_ID=
# Bech32 `suiprivkey...` of the issuer keypair that holds the parent NFT and signs leaf mints. SECRET.
# SEPARATE from ENOKI_PRIVATE_API_KEY and the future AGENT_PRIVATE_KEY — never reuse keys.
HANDLE_ISSUER_PRIVATE_KEY=
# Parent SuiNS domain (defaults to suize.sui if unset). Handles are <name>@suize = <name>.suize.sui.
SUINS_PARENT_DOMAIN=suize.sui

# The no-code hosted merchant door (GET/POST /charge/<token>). ONE Ed25519 key signs
# the stateless charge token AND the settled-order webhook (merchant verifies via
# @suize/pay/webhook). Public key published at GET /charge/pubkey. SECRET, env-only,
# SEPARATE from every other key — never reuse. Unset → the /charge door answers 503.
# Bech32 `suiprivkey...`.
SUIZE_CHARGE_PRIVATE_KEY=

# Deploy module — "Suize Deploy" (Vercel for Sui). FULLY ON-CHAIN site registry.
# The module is ENABLED only when DEPLOY_WALLET_PRIVATE_KEY is set; until then
# every /deploy, /sites, /domains op returns 503 "deploy not configured" (the rest
# of the backend runs fine). Storage goes through the Walrus HTTP PUBLISHER (no CLI);
# there is NO Enoki sponsor here (the agent signs nothing).
#
# Bech32 `suiprivkey...` of the deploy SERVICE WALLET that signs Site PTBs. SECRET.
# SEPARATE from ENOKI_PRIVATE_API_KEY / HANDLE_ISSUER_PRIVATE_KEY — never reuse keys.
# On the PUBLIC TESTNET publisher the OPERATOR pays the WAL, so this wallet needs only
# a LITTLE SUI for the on-chain create_site gas — no WAL needed for testnet.
DEPLOY_WALLET_PRIVATE_KEY=
# FALLBACK service-wallet key: when DEPLOY_WALLET_PRIVATE_KEY is unset, the deploy
# module (and the storage-extend cron) falls back to AGENT_PRIVATE_KEY — the shared
# backend service wallet — so ONE funded key can serve both for an MVP/demo. SECRET.
# Bech32 `suiprivkey...`. Repo rule: never reuse keys across modules in prod; one key
# is fine for the demo. (The agent module is a stub, so this is otherwise unconsumed.)
AGENT_PRIVATE_KEY=
# The Deploy MERCHANT address — who the deploy revenue pays. UNSET (or == treasury) →
# FIRST-PARTY: a single full-amount output, deploy income IS treasury income. Set to a
# REAL merchant address (≠ treasury) → each deploy is a rail charge to that merchant:
# net → merchant, the 2%/$0.01 fee leg → treasury (the on-chain leg a wallet reads as a
# `charged` merchant payment, so it lands in that merchant's business ledger). On mainnet
# this is the real Deploy merchant; on testnet, the demo merchant (e.g. sceat's address).
# SUIZE_DEPLOY_MERCHANT=0x...
# Walrus storage duration in epochs (default 30 ≈ ~1 month; testnet epoch ≈ 1 day, max ~183).
DEPLOY_EPOCHS=30
# Base zone for free subdomains: https://<base36(siteId)>.<DEPLOY_BASE_DOMAIN>. Default
# suize.site (its own zone — free first-level wildcard SSL; the dashboard stays deploy.suize.io).
DEPLOY_BASE_DOMAIN=suize.site
# Walrus AGGREGATOR base (used to READ back uploaded blobs; the worker uses the same).
# Unset = the public aggregator for SUI_NETWORK (shared WALRUS_DEFAULTS table).
WALRUS_AGGREGATOR=
# Walrus HTTP PUBLISHER base — the deploy module PUTs quilts/blobs here (no CLI, no keystore).
# Unset = the public publisher for SUI_NETWORK (on testnet the operator pays the WAL).
# The SAME code serves a self-hosted MAINNET publisher — just point this at it.
WALRUS_PUBLISHER_URL=

# Optional Cloudflare-for-SaaS (Custom Hostnames) adapter — custom-domain auto-SSL.
# When BOTH are set the deploy module provisions the custom hostname on link;
# otherwise it returns manual-CNAME instructions (never a build blocker).
# Cloudflare API token with the "Custom Hostnames Edit" scope. SECRET.
CF_API_TOKEN=
# Cloudflare zone id that hosts DEPLOY_BASE_DOMAIN.
CF_ZONE_ID=

# Walrus storage auto-renewal — the deterministic subscription↔storage cron. The
# subs module CHARGES (push, user-signed); this cron's only job is to keep a PAID
# site's Walrus storage extended so it never lapses (it does NOT charge). Enabled only
# when the deploy wallet is set AND the subs module is published. Two triggers: an
# on-settle hook (per sponsored renewal) + this safety cron. NOTE: extends pay WAL —
# the deploy service wallet must hold a Coin<WAL>.
# Safety-cron interval in ms (default 21600000 = 6h).
# EXTEND_TICK_MS=21600000
# Walrus epochs added per extend (default 35; clamped so a blob never ends more
# than ~50 epochs past the current epoch — the Walrus max is ~53).
# RENEWAL_EPOCHS=35
# Extend cushion (default 5): a blob ending within this many epochs of NOW, on a
# still-paid sub, gets repaired this pass.
# RENEWAL_SAFETY_EPOCHS=5
# Deploy subscription period in ms. Default = the shared 30-day constant; override
# ONLY for demos (e.g. 120000 = 2-minute periods, paired with a short tick).
# DEPLOY_SUB_PERIOD_MS=
# WAL coin type the extend payment is drawn from (default = testnet WAL; set for mainnet).
# WAL_COIN_TYPE=
# Walrus shared System object id (default = testnet; set for mainnet). The Walrus
# PACKAGE is resolved at runtime from this object's package_id field — never pinned.
# WALRUS_SYSTEM_OBJECT=

# --- Brain (the wallet AI) — the FENCED inference module (CLAUDE.md LOCKED #5,
# amended 2026-06-14). Holds the Anthropic key and runs Claude to power the PAY
# wallet's conversation, but returns ONLY narration + PROPOSED actions — it never
# signs, settles, sponsors, or touches a key (the wallet is the sole signer; the
# number wall stands). The brain WS frame returns "not configured" until
# ANTHROPIC_API_KEY is set; the rest of the backend runs fine.
# The key is SERVER-ONLY — NEVER a VITE_/frontend var, never in a bundle (a Vite
# frontend build would leak it). SECRET.
ANTHROPIC_API_KEY=
# Model — Haiku ONLY (owner 2026-06-14: no paid wallet tier; no model routing).
# BRAIN_MODEL=claude-haiku-4-5
# STRICT per-user daily token cap (input+output), keyed by the verified zkLogin
# address. Over it, the user gets the work-in-progress notice and NO model call.
# BRAIN_DAILY_TOKEN_MAX=60000
# Hard ceiling on one turn's output tokens (default 1024).
# BRAIN_MAX_OUTPUT_TOKENS=1024

# --- Memory ("it remembers you") — MemWal (Walrus's agent-memory SDK). The brain
# does recall→inject→remember around each turn; it's BEST-EFFORT and NEVER blocks a
# chat or a payment. Memory is ENABLED only when MEMWAL_MASTER_KEY + the two contract
# ids are all set; otherwise recall returns nothing and onboarding is a no-op (the
# rest of the backend runs fine).
#
# Per-user delegate keys are DERIVED via HKDF from this ONE master secret + the user's
# address — no per-user store, deterministic across replicas. SERVER-ONLY, SECRET,
# and NEVER ROTATE: the HKDF root anchors every memory; a new key makes all prior
# memories unreadable. The delegate signs MEMORY ONLY — it can never move money.
MEMWAL_MASTER_KEY=
# MemWal on-chain ids — MUST match SUI_NETWORK (a testnet account ↔ the staging relayer).
#   TESTNET: PACKAGE 0xcf6ad755a1cdff7217865c796778fabe5aa399cb0cf2eba986f4b582047229c6
#            REGISTRY 0xe80f2feec1c139616a86c9f71210152e2a7ca552b20841f2e192f99f75864437
#   MAINNET: PACKAGE 0xcee7a6fd8de52ce645c38332bde23d4a30fd9426bc4681409733dd50958a24c6
#            REGISTRY 0x0da982cefa26864ae834a8a0504b904233d49e20fcc17c373c8bed99c75a7edd
MEMWAL_PACKAGE_ID=
MEMWAL_REGISTRY_ID=
# MemWal relayer base — embeds + Seal-encrypts + stores on Walrus. MUST match the network.
#   TESTNET https://relayer-staging.memory.walrus.xyz  ·  MAINNET https://relayer.memory.walrus.xyz
# MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz
# Namespace partitioning memories within an account (default "suize").
# MEMWAL_NAMESPACE=suize
