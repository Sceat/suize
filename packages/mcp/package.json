{
  "name": "@suize/mcp",
  "version": "0.3.2",
  "description": "Local stdio MCP server — let your coding assistant (Claude Code / Cursor / Codex) deploy a static site to Walrus through Suize in one tool call. Signs a gasless x402 payment with a local key: the key never leaves your machine, and you own every site you deploy.",
  "private": false,
  "type": "module",
  "bin": {
    "suize-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "nanotar": "^0.3.0"
  },
  "devDependencies": {
    "@suize/shared": "workspace:^",
    "@suize/x402": "workspace:^",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "402",
    "x402",
    "deploy",
    "walrus",
    "sui",
    "static-site",
    "suize",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sceat/suize.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://suize.io"
}
