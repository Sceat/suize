{
  "name": "@suize/pay",
  "version": "0.3.1",
  "description": "Accept agent payments over HTTP 402 on Sui — one middleware, vanilla x402 V2, no keys, no signup. Your Sui address is your account.",
  "private": false,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./subs": "./src/subs.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "tsup && bun run scripts/dist-pkg.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "402",
    "payments",
    "agents",
    "sui",
    "usdc",
    "suize"
  ],
  "license": "MIT"
}
