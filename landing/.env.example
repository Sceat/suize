# Copy to .env.local and fill in values. Anything prefixed with VITE_ is
# exposed to the client at build time — never put real secrets here.

# Base URL of the suize-api backend (without trailing slash).
# Local dev: leave empty to simulate success after 600ms.
# Prod (Vercel): https://api.suize.io
VITE_API_URL=

# Cloudflare Turnstile site key (public — it's embedded in the client HTML
# at runtime, so it's safe to commit. Hostname-bound to suize.io / www.suize.io
# / localhost; only those origins can use it effectively).
# Override via .env.local if you ever need a different widget for testing.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADXXYizvgq8g608o
