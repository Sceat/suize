# ── Dependencies ─────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
# Bun is the one toolchain — keep foreign lockfiles out of the workspace.
package-lock.json
yarn.lock

# ── Build output ─────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
*.local
*.tsbuildinfo

# ── Env / secrets ────────────────────────────────────────────────────
# EVERY .env flavor is ignored by default; whitelisted: the committed templates
# (.env.example) and the frontend apps' prod build config (PUBLIC Vite-inlined
# values that ship in the JS bundle — each file header documents "safe to
# commit"). The whitelist is apps/-scoped ON PURPOSE: a future backend
# .env.production (real secrets) stays ignored.
.env
.env.*
!.env.example
# Whitelist the EXACT existing app prod configs (publishable VITE_ values ONLY —
# never a secret). Pinned per-file (not apps/*) so a future app's .env.production
# can't be silently committed — add it here deliberately.
!apps/crash/.env.production
!apps/deploy/.env.production
!apps/wallet/.env.production
*.pem
*.key

# ── Logs ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/

# ── Editor / IDE ─────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursor/

# ── OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Tooling artifacts ────────────────────────────────────────────────
.playwright-mcp/
playwright-report/
test-results/
.cache/
.parcel-cache/
.next/
.nuxt/
.turbo/
coverage/
*.lcov

# ── Local screenshots / scratch ──────────────────────────────────────
screenshots/
*.png
*.jpg
*.jpeg
# Everything under any public/ dir is a versioned brand asset, not scratch — the
# `**/` prefix is load-bearing: the monorepo nests public/ under apps/*/ (a bare
# `public/**` only matches a top-level public/, which is why logo.png + the PWA
# icons were silently un-tracked). This overrides the *.png/*.jpg rules above.
!**/public/**/*.png
!**/public/**/*.jpg
!**/public/**/*.jpeg
!**/og-image*.png
!**/favicon*.png

# ── Vite ─────────────────────────────────────────────────────────────
.vite/

# ── Owner strategy docs — never in the public tree ───────────────────
marketing/
